# CIRO Backend — Environment Variables
# ======================================
# Copy this to .env and fill in values.
# NOTE: The system works WITHOUT any API keys (Open-Meteo is free).

# ── Optional API Keys ──
# OpenWeatherMap (optional — Open-Meteo covers all weather needs for free)
OPENWEATHER_API_KEY=

# Google Maps (optional — for traffic congestion data)
GOOGLE_MAPS_API_KEY=

# ── Firebase (Production Only) ──
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# ── Server Config ──
ENVIRONMENT=development
